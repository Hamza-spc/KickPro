# ─── PostgreSQL ───────────────────────────────────────────────
# Local Docker: DB_HOST=postgres, DB_URL=jdbc:postgresql://postgres:5432/kickpro
# AWS RDS: use your RDS endpoint only — do NOT duplicate DB_URL lines in .env
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kickpro
DB_USERNAME=kickpro
DB_PASSWORD=kickpro
DB_URL=jdbc:postgresql://postgres:5432/kickpro

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Kafka ────────────────────────────────────────────────────
# Use kafka:29092 inside Docker, localhost:9092 when running backend on host
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─── JWT (Phase 1) — generate with: openssl rand -hex 32 ─────
JWT_SECRET=

# ─── Cloudinary (Phase 1) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── AI Service ───────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8000

# ─── Gemini (Phase 5) ─────────────────────────────────────────
GEMINI_API_KEY=
